<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bibliomanager.controller.HistoryController">
   <top>
      <HBox prefHeight="55.0" prefWidth="1111.0" styleClass="header-container" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="55.0" prefWidth="240.0" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <ImageView fitHeight="30.0" fitWidth="33.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../icons/history.png" />
                     </image>
                  </ImageView>
                  <Label text="History">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Label>
                  <Label fx:id="totalBadge" alignment="CENTER" prefHeight="28.0" prefWidth="122.0" styleClass="total-badge" text="63 records" textFill="WHITE">
                     <font>
                        <Font size="17.0" />
                     </font>
                  </Label>
               </children>
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </HBox>
         </children>
      </HBox>
   </top>
   <center>
      <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <VBox prefHeight="708.0" prefWidth="902.0" spacing="20.0" HBox.hgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT" minHeight="60.0" prefHeight="53.0" prefWidth="770.0" spacing="10.0" styleClass="div-container">
                     <children>
                        <StackPane alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="369.0">
                           <children>
                              <TextField fx:id="searchField" minHeight="37.0" prefHeight="37.0" prefWidth="356.0" promptText="Search student or book">
                                 <padding>
                                    <Insets left="40.0" />
                                 </padding>
                              </TextField>
                              <ImageView fitHeight="22.0" fitWidth="36.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@../icons/search.png" />
                                 </image>
                                 <StackPane.margin>
                                    <Insets left="10.0" />
                                 </StackPane.margin>
                              </ImageView>
                           </children>
                        </StackPane>
                        <ComboBox fx:id="periodFilter" minHeight="37.0" prefHeight="26.0" prefWidth="138.0" promptText="All time" />
                        <ComboBox fx:id="statusFilter" minHeight="37.0" prefHeight="37.0" prefWidth="137.0" promptText="All status" />
                        <Region prefHeight="60.0" prefWidth="123.0" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleExportPdf" prefHeight="35.0" prefWidth="143.0" styleClass="pdf-btn" text="PDF Report" textFill="WHITE">
                           <font>
                              <Font size="16.0" />
                           </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#handleExportCsv" prefHeight="35.0" prefWidth="143.0" styleClass="add-btn" text="Export CSV" textFill="WHITE">
                           <font>
                              <Font size="16.0" />
                           </font>
                        </Button>
                     </children>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                     <padding>
                        <Insets left="15.0" right="15.0" />
                     </padding>
                  </HBox>
                  <TableView fx:id="historyTable" prefHeight="458.0" prefWidth="750.0" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colStudent" prefWidth="121.0" text="Student" />
                        <TableColumn fx:id="colBook" prefWidth="119.0" text="Book" />
                        <TableColumn fx:id="colLoanDate" prefWidth="96.0" text="Loan Date" />
                        <TableColumn fx:id="colDueDate" prefWidth="111.0" text="Due Date" />
                        <TableColumn fx:id="colReturnDate" prefWidth="103.0" text="Return Date" />
                        <TableColumn fx:id="colStatus" prefWidth="94.0" text="Status" />
                        <TableColumn fx:id="colRegisteredBy" prefWidth="115.0" text="Registered By" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
               </padding>
            </VBox>
         </children>
      </HBox>
   </center>
   <stylesheets>
      <URL value="@../css/books.css" />
      <URL value="@../css/book-dialog.css" />
   </stylesheets>
</BorderPane>
