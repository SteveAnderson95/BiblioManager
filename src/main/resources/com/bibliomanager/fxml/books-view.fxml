<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" styleClass="main-container" stylesheets="@../css/books.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bibliomanager.controller.BookController">
   <top>
      <HBox prefHeight="55.0" prefWidth="960.0" styleClass="header-container" BorderPane.alignment="CENTER_LEFT">
         <children>
            <HBox alignment="CENTER" prefHeight="90.0" prefWidth="201.0" spacing="10.0">
               <children>
                  <ImageView fitHeight="25.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../icons/openBook.png" />
                     </image>
                  </ImageView>
                  <Label text="Books">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                  </Label>
                  <Label fx:id="totalBadge" alignment="CENTER" prefHeight="24.0" prefWidth="82.0" styleClass="total-badge" text="68 total" textFill="WHITE">
                     <font>
                        <Font size="17.0" />
                     </font>
                  </Label>
               </children>
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </HBox>
            <Region prefHeight="90.0" prefWidth="3.0" HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" prefHeight="90.0" prefWidth="491.0" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <StackPane alignment="CENTER_LEFT" prefHeight="90.0" prefWidth="252.0">
                     <children>
                        <TextField fx:id="searchField" prefHeight="41.0" prefWidth="260.0" promptText="Search by title, author, ISBN,...">
                           <padding>
                              <Insets left="40.0" />
                           </padding>
                        </TextField>
                        <ImageView fitHeight="22.0" fitWidth="36.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../icons/search.png" />
                           </image>
                           <StackPane.margin>
                              <Insets left="10.0" />
                           </StackPane.margin>
                        </ImageView>
                     </children>
                  </StackPane>
                  <ComboBox fx:id="categoryFilter" prefHeight="26.0" prefWidth="138.0" promptText="All Categories" />
                  <ComboBox fx:id="statusFilter" prefHeight="28.0" prefWidth="114.0" promptText="All status" />
               </children>
            </HBox>
            <Region prefHeight="90.0" prefWidth="0.0" HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER" prefHeight="90.0" prefWidth="134.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleAdd" prefHeight="34.0" prefWidth="133.0" styleClass="add-btn" text="Add Book" textFill="WHITE">
                     <graphic>
                        <ImageView fitHeight="20.0" fitWidth="19.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../icons/add.png" />
                           </image>
                        </ImageView>
                     </graphic>
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Button>
               </children>
               <HBox.margin>
                  <Insets right="20.0" />
               </HBox.margin>
            </HBox>
         </children>
      </HBox>
   </top>
   <center>
      <HBox alignment="CENTER" spacing="15.0" styleClass="center-container" BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="booksTable" HBox.hgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colTitle" prefWidth="163.0" text="Title" />
                <TableColumn fx:id="colAuthor" prefWidth="147.0" text="Author" />
                  <TableColumn fx:id="colCategory" prefWidth="113.0" text="Category" />
                  <TableColumn fx:id="colTotal" prefWidth="61.0" text="Total" />
                  <TableColumn fx:id="colAvailable" prefWidth="77.0" text="Available" />
                  <TableColumn fx:id="colStatus" prefWidth="110.0" text="Status" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <VBox fx:id="detailPanel" alignment="CENTER" minWidth="270.0" prefWidth="270.0" spacing="10.0" styleClass="detail-panel">
               <children>
                  <HBox prefHeight="44.0" prefWidth="268.0" styleClass="detail-header">
                     <children>
                        <Label text="Book Details" textFill="WHITE" HBox.hgrow="ALWAYS">
                           <font>
                              <Font name="System Bold" size="17.0" />
                           </font>
                        </Label>
                        <Region prefHeight="26.0" prefWidth="91.0" />
                        <Button mnemonicParsing="false" onAction="#closeDetailPanel" prefHeight="20.0" prefWidth="20.0" styleClass="close-btn" textFill="TRANSPARENT">
                           <graphic>
                              <ImageView fitHeight="14.0" fitWidth="12.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@../icons/close.png" />
                                 </image>
                              </ImageView>
                           </graphic>
                        </Button>
                     </children>
                  </HBox>
                  <StackPane minHeight="200.0" prefHeight="200.0" prefWidth="190.0" styleClass="poster-container" VBox.vgrow="ALWAYS">
                     <children>
                        <ImageView fx:id="posterImageView" fitHeight="200.0" fitWidth="190.0" pickOnBounds="true" preserveRatio="true" styleClass="poster-image" />
                        <Label fx:id="posterPlaceholderLabel" styleClass="info-label" text="No cover available" />
                     </children>
                  </StackPane>
                  <VBox alignment="CENTER_LEFT" VBox.vgrow="ALWAYS">
                     <children>
                        <Label styleClass="info-label" text="TITLE" />
                        <Label fx:id="detailTitle" styleClass="info-value" text="Effective Java" />
                        <Label styleClass="info-label" text="AUTHOR" />
                        <Label fx:id="detailAuthor" styleClass="info-value" text="Joshua Bloch" />
                        <Label styleClass="info-label" text="ISBN" />
                        <Label fx:id="detailIsbn" styleClass="info-value" text="978-1212" />
                        <Label styleClass="info-label" text="CATEGORY" />
                        <Label fx:id="detailCategory" styleClass="info-value" text="Computer Science" />
                        <Label styleClass="info-label" text="DESCRIPTION" />
                        <Label fx:id="detailDescription" styleClass="info-value" text="Computer Science" wrapText="true" />
                     </children>
                     <padding>
                        <Insets left="25.0" />
                     </padding>
                  </VBox>
                  <HBox alignment="CENTER" prefHeight="69.0" prefWidth="268.0" spacing="20.0">
                     <children>
                        <VBox alignment="CENTER" prefWidth="70.0" styleClass="stock-card">
                           <children>
                              <Label fx:id="detailTotal" styleClass="stock-number" text="5" />
                              <Label styleClass="stock-label" text="Total" />
                           </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="87.0" prefWidth="70.0" styleClass="stock-card">
                           <children>
                              <Label fx:id="detailAvailable" text="3" textFill="#269a4d">
                                 <styleClass>
                                    <String fx:value="stock-number" />
                                    <String fx:value="stock-number-green" />
                                 </styleClass>
                              </Label>
                              <Label styleClass="stock-label" text="Available" />
                           </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="87.0" prefWidth="70.0" styleClass="stock-card">
                           <children>
                              <Label fx:id="detailOnLoan" text="2">
                                 <styleClass>
                                    <String fx:value="stock-number" />
                                    <String fx:value="stock-number-orange" />
                                 </styleClass>
                              </Label>
                              <Label styleClass="stock-label" text="On Loan" />
                           </children>
                        </VBox>
                     </children>
                     <VBox.margin>
                        <Insets bottom="20.0" />
                     </VBox.margin>
                  </HBox>
                  <HBox alignment="CENTER" spacing="20.0" styleClass="detail-footer">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleEdit" styleClass="btn-edit" text="Edit" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleDelete" styleClass="btn-delete" text="Delete" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
         <BorderPane.margin>
            <Insets top="15.0" />
         </BorderPane.margin>
      </HBox>
   </center>
</BorderPane>
